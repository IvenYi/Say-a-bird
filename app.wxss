/* Global Design System based on Geometric Flat & Color-Blocking */

page {
  /* 基础变量定义 */
  --bg-sky-dawn-1: #FDF2F0;
  --bg-sky-dawn-2: #E3F2FD;
  --bg-sky-day-1: #E3F2FD;
  --bg-sky-day-2: #FFFFFF;
  --bg-sky-dusk-1: #FFF3E0;
  --bg-sky-dusk-2: #FFCCBC;
  --bg-sky-night-1: #1A237E;
  --bg-sky-night-2: #121212;

  --color-forest: #4A6741;
  --color-block-green: #A8D5BA;
  --color-block-green-dark: #81BA95;
  --color-block-orange: #FFAB91;
  --color-block-orange-dark: #E2957C;
  --color-paper: #F5F5F5;
  
  --color-text-main: #37474F;
  --color-text-secondary: #78909C;
  
  /* 几何感硬阴影 */
  --shadow-hard: 0 8rpx 0 rgba(0, 0, 0, 0.05);
  --shadow-hard-active: 0 2rpx 0 rgba(0, 0, 0, 0.05);
  
  --radius-geometric: 16rpx;
  
  background-color: var(--color-paper);
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  color: var(--color-text-main);
  line-height: 1.6;
  letter-spacing: 0.5px;
}

/* 统一重置 */
view, text, scroll-view, swiper, button {
  box-sizing: border-box;
}

/* 全局颗粒感叠加层 */
.noise-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  pointer-events: none;
  opacity: 0.03;
  /* 使用 base64 噪点图或渐变模拟颗粒感 */
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
}

/* 统一按钮样式：硬阴影风格 */
.btn-geometric {
  background: var(--color-block-orange);
  color: white;
  border-radius: var(--radius-geometric);
  box-shadow: var(--shadow-hard);
  transition: all 0.1s ease;
  border: none;
  font-weight: 600;
}

.btn-geometric:active {
  transform: translateY(6rpx);
  box-shadow: var(--shadow-hard-active);
}

.status-bar-placeholder {
  height: 120rpx; /* 基础预留高度 */
  width: 100%;
}
