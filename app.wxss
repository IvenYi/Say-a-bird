/* Global Design System - Say a Bird V2 */
/* Style: Stroke-less Noise Pastel Picture Book */

page {
  /* 天空时段背景渐变变量 */
  --bg-sky-dawn-1: #FDF2F0; --bg-sky-dawn-2: #E3F2FD;
  --bg-sky-day-1: #E3F2FD;   --bg-sky-day-2: #FFFFFF;
  --bg-sky-dusk-1: #FFF3E0;  --bg-sky-dusk-2: #FFCCBC;
  --bg-sky-night-1: #1A237E; --bg-sky-night-2: #121212;

  /* 核心资产色 (Pastel Colors) */
  --color-mint: #A8D5BA;       /* 灰豆绿 */
  --color-mint-dark: #81BA95;
  --color-blue: #87A9BE;       /* 莫兰迪蓝 */
  --color-blue-dark: #6B8EAB;
  --color-warm-orange: #FFAB91; /* 柔橙 */
  --color-paper: #F5F5F5;      /* 纸张白 */
  
  /* 文字层级 */
  --text-main: #4A4A4A;        /* 暖深灰 */
  --text-secondary: #78909C;   /* 次要灰 */
  
  /* 阴影体系 (V2 核心弥散阴影) */
  --shadow-soft: 0 10rpx 20rpx rgba(0, 0, 0, 0.05);
  --shadow-elevated: 0 20rpx 40rpx rgba(0, 0, 0, 0.08);
  --shadow-accent: 0 16rpx 32rpx rgba(255, 171, 145, 0.2);
  
  /* 圆角规范 */
  --radius-zen: 24rpx;
  --radius-pill: 100rpx;
  
  background-color: var(--color-paper);
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  color: var(--text-main);
  line-height: 1.7;
  letter-spacing: 0.5px;
}

/* 统一重置 */
view, text, scroll-view, swiper, button, textarea {
  box-sizing: border-box;
}

/* 全局噪点质感层 - 3% 透明度 */
.noise-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999;
  pointer-events: none;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
}

/* 标准禅意按钮 */
.btn-zen {
  background: var(--color-warm-orange);
  color: #FFFFFF;
  border-radius: var(--radius-pill);
  padding: 24rpx 60rpx;
  font-weight: 500;
  box-shadow: var(--shadow-accent);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-zen:active {
  transform: scale(0.96);
  box-shadow: 0 8rpx 16rpx rgba(255, 171, 145, 0.15);
}

.btn-zen[disabled] {
  background: #E0E0E0;
  color: #9E9E9E;
  box-shadow: none;
}

/* 标准禅意卡片 */
.card-zen {
  background: #FFFFFF;
  border-radius: var(--radius-zen);
  padding: 40rpx;
  box-shadow: var(--shadow-elevated);
}

/* 沉浸式状态栏占位 */
.status-bar-placeholder {
  height: env(safe-area-inset-top);
  width: 100%;
}
