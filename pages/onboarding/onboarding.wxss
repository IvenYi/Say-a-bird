/* pages/onboarding/onboarding.wxss */
.onboarding-container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(to bottom, var(--bg-sky-dawn-1), var(--bg-sky-dawn-2));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  position: relative;
}

/* 欢迎页 */
.welcome-page {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  min-height: 80vh;
}

.welcome-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
  text-align: center;
}

.welcome-image {
  width: 320rpx;
  height: 320rpx;
  margin-bottom: 80rpx;
  filter: drop-shadow(0 20rpx 40rpx rgba(0,0,0,0.05));
}

.welcome-title {
  font-size: 52rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 24rpx;
  letter-spacing: 4rpx;
}

.welcome-subtitle {
  font-size: 36rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
  font-weight: 300;
}

.welcome-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  opacity: 0.8;
}

.welcome-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
}

.skip-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  opacity: 0.6;
}

/* 输入引导页 */
.input-guide-page {
  width: 100%;
  display: flex;
  flex-direction: column;
}

.guide-header {
  margin-bottom: 80rpx;
}

.guide-title {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--text-main);
  display: block;
  margin-bottom: 20rpx;
}

.guide-subtitle {
  font-size: 30rpx;
  color: var(--text-secondary);
  display: block;
}

.input-area {
  width: 100%;
  margin-bottom: 60rpx;
}

.input-textarea {
  width: 100%;
  min-height: 360rpx;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20px);
  border-radius: var(--radius-zen);
  font-size: 34rpx;
  line-height: 1.7;
  box-shadow: var(--shadow-elevated);
}

.input-tips {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 80rpx;
}

.tip-item {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-style: italic;
}

/* 鸟类生成页 */
.bird-generate-page {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bird-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.bird-image {
  width: 440rpx;
  height: 440rpx;
  margin-bottom: 40rpx;
}

.bird-name {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 24rpx;
}

.bird-desc {
  font-size: 30rpx;
  color: var(--text-secondary);
}

.bird-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 80rpx;
  text-align: center;
}

.info-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 图鉴介绍页 */
.gallery-intro-page {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.intro-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.intro-image {
  width: 380rpx;
  height: 380rpx;
  margin-bottom: 60rpx;
}

.intro-title {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 30rpx;
}

.intro-desc {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.progress-preview {
  width: 100%;
  margin-bottom: 80rpx;
  padding: 0 40rpx;
}

.progress-text {
  font-size: 30rpx;
  color: var(--text-main);
  display: block;
  margin-bottom: 24rpx;
  text-align: center;
}

/* 进度指示器 */
.step-indicator {
  position: fixed;
  bottom: 80rpx;
  display: flex;
  gap: 20rpx;
}

.step-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(var(--color-warm-orange-rgb), 0.2);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.step-dot.active {
  background: var(--color-warm-orange);
  width: 48rpx;
  border-radius: 8rpx;
}

/* 动画重定义 */
.fade-in { animation: zenFadeIn 1s ease-out forwards; }
.fly-in { animation: birdFlyIn 1.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }

@keyframes zenFadeIn {
  from { opacity: 0; transform: translateY(30rpx); filter: blur(10px); }
  to { opacity: 1; transform: translateY(0); filter: blur(0); }
}

@keyframes birdFlyIn {
  0% { opacity: 0; transform: translateY(-80rpx) scale(0.8) rotate(-5deg); }
  100% { opacity: 1; transform: translateY(0) scale(1) rotate(0); }
}
