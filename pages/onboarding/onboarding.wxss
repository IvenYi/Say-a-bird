/* pages/onboarding/onboarding.wxss */
.onboarding-container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #E3F2FD 0%, #BBDEFB 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

/* 欢迎页 */
.welcome-page {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  min-height: 80vh;
  opacity: 0;
}

.welcome-page.fade-in {
  animation: fadeIn 0.8s ease-in forwards;
}

.welcome-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
}

.welcome-image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 60rpx;
}

.welcome-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1976D2;
  margin-bottom: 20rpx;
}

.welcome-subtitle {
  font-size: 36rpx;
  color: #424242;
  margin-bottom: 40rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #757575;
}

.welcome-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.skip-text {
  font-size: 28rpx;
  color: #9E9E9E;
  text-decoration: underline;
}

/* 输入引导页 */
.input-guide-page {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.guide-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.guide-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1976D2;
  display: block;
  margin-bottom: 20rpx;
}

.guide-subtitle {
  font-size: 28rpx;
  color: #757575;
  display: block;
}

.input-area {
  width: 100%;
  margin-bottom: 40rpx;
}

.input-textarea {
  width: 100%;
  min-height: 300rpx;
  padding: 30rpx;
  background: white;
  border-radius: 20rpx;
  font-size: 32rpx;
  line-height: 1.6;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.input-placeholder {
  color: #BDBDBD;
}

.input-tips {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 60rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #757575;
}

/* 鸟类生成页 */
.bird-generate-page {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0;
}

.bird-generate-page.fade-in {
  animation: fadeIn 1s ease-in forwards;
}

.bird-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.bird-image {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 40rpx;
}

.bird-image.fly-in {
  animation: flyIn 1.2s ease-out forwards;
}

.bird-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #1976D2;
  margin-bottom: 20rpx;
}

.bird-desc {
  font-size: 28rpx;
  color: #757575;
}

.bird-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 60rpx;
  text-align: center;
}

.info-text {
  font-size: 28rpx;
  color: #616161;
}

/* 图鉴介绍页 */
.gallery-intro-page {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.intro-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.intro-image {
  width: 350rpx;
  height: 350rpx;
  margin-bottom: 40rpx;
}

.intro-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1976D2;
  margin-bottom: 30rpx;
}

.intro-desc {
  font-size: 28rpx;
  color: #757575;
  margin-bottom: 10rpx;
}

.progress-preview {
  width: 100%;
  margin-bottom: 60rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #424242;
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
}

/* 通用按钮 */
.btn-primary {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #42A5F5 0%, #1976D2 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 45rpx;
  border: none;
  box-shadow: 0 8rpx 16rpx rgba(25, 118, 210, 0.3);
}

.btn-primary::after {
  border: none;
}

/* 进度指示器 */
.step-indicator {
  position: fixed;
  bottom: 60rpx;
  display: flex;
  gap: 20rpx;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  transition: all 0.3s ease;
}

.step-dot.active {
  background: #1976D2;
  width: 40rpx;
  border-radius: 8rpx;
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes flyIn {
  0% {
    opacity: 0;
    transform: translateY(-100rpx) scale(0.5);
  }
  60% {
    opacity: 1;
    transform: translateY(20rpx) scale(1.1);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
