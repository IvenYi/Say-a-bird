/* pages/diary/diary.wxss */
.diary-container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(to bottom, var(--bg-sky-day-1) 0%, var(--color-paper) 40%);
  padding: 80rpx 40rpx;
}

/* 鸟类展示区 */
.bird-section {
  background: white;
  border-radius: var(--radius-zen);
  padding: 60rpx 40rpx;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow-elevated);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bird-image {
  width: 340rpx;
  height: 340rpx;
  margin-bottom: 40rpx;
}

.bird-info {
  width: 100%;
  text-align: center;
}

.bird-name {
  font-size: 52rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 16rpx;
}

.bird-emotion {
  font-size: 26rpx;
  color: var(--color-blue-dark);
  background: rgba(135, 169, 190, 0.1);
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  display: inline-block;
  margin-bottom: 32rpx;
}

.bird-knowledge {
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--color-paper);
  padding: 32rpx;
  border-radius: 20rpx;
  line-height: 1.7;
  text-align: left;
  font-style: italic;
}

/* 日记内容区 */
.diary-section {
  background: white;
  border-radius: var(--radius-zen);
  padding: 60rpx 40rpx;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow-elevated);
}

.diary-header {
  margin-bottom: 48rpx;
  padding-bottom: 32rpx;
}

.diary-time {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 24rpx;
}

.diary-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  font-size: 24rpx;
  color: var(--color-mint-dark);
  background: rgba(168, 213, 186, 0.1);
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
}

.diary-content {
  line-height: 2;
}

.content-text {
  font-size: 36rpx;
  color: var(--text-main);
}

/* 元数据区 */
.meta-section {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.meta-item {
  flex: 1;
  background: white;
  border-radius: var(--radius-zen);
  padding: 32rpx 24rpx;
  box-shadow: var(--shadow-soft);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.meta-label {
  font-size: 20rpx;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.meta-value {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 600;
}

/* 底部操作 */
.bottom-actions {
  margin-top: 60rpx;
}

.delete-btn {
  background: transparent;
  color: #EF5350;
  border-radius: var(--radius-zen);
  height: 100rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  opacity: 0.6;
}

.delete-btn:active {
  opacity: 1;
  background: rgba(239, 83, 80, 0.05);
}
