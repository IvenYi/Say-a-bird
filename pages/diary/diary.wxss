/* pages/diary/diary.wxss */
.diary-container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(to bottom, var(--bg-sky-day-1) 0%, var(--color-paper) 40%);
  padding: 60rpx 40rpx;
}

/* 噪点层依然需要 */
.noise-overlay {
  position: fixed;
  inset: 0;
  z-index: 10;
  pointer-events: none;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
}

/* 鸟类展示区：色块艺术展示 */
.bird-section {
  background: white;
  border-radius: var(--radius-geometric);
  padding: 60rpx 40rpx;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow-hard);
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 4rpx solid rgba(0,0,0,0.02);
}

.bird-image {
  width: 320rpx;
  height: 320rpx;
  margin-bottom: 40rpx;
  image-rendering: pixelated; /* 强化像素/几何块感 */
}

.bird-info {
  width: 100%;
  text-align: center;
}

.bird-name {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--color-text-main);
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 16rpx;
}

.bird-emotion {
  font-size: 24rpx;
  color: var(--color-block-orange-dark);
  background: rgba(255, 171, 145, 0.1);
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  display: inline-block;
  margin-bottom: 30rpx;
}

.bird-knowledge {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: var(--color-paper);
  padding: 24rpx;
  border-radius: 12rpx;
  line-height: 1.6;
  text-align: left;
  font-style: italic;
}

/* 日记内容区：纸张书写感 */
.diary-section {
  background: white;
  border-radius: var(--radius-geometric);
  padding: 50rpx 40rpx;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow-hard);
}

.diary-header {
  margin-bottom: 40rpx;
  padding-bottom: 30rpx;
  border-bottom: 4rpx dashed var(--color-paper);
}

.diary-time {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 20rpx;
}

.diary-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  font-size: 22rpx;
  color: var(--color-block-green-dark);
  background: rgba(168, 213, 186, 0.1);
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
}

.diary-content {
  line-height: 2;
}

.content-text {
  font-size: 34rpx;
  color: var(--color-text-main);
}

/* 元数据区：色块拼贴式统计 */
.meta-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.meta-item {
  flex: 1;
  background: white;
  border-radius: var(--radius-geometric);
  padding: 30rpx 20rpx;
  box-shadow: var(--shadow-hard);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.meta-label {
  font-size: 18rpx;
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.meta-value {
  font-size: 26rpx;
  color: var(--color-text-main);
  font-weight: bold;
}

/* 底部操作 */
.bottom-actions {
  margin-top: 40rpx;
}

.delete-btn {
  background: transparent;
  border: 2rpx solid #FFCDD2;
  color: #EF5350;
  border-radius: var(--radius-geometric);
  height: 90rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.delete-btn::after {
  border: none;
}
