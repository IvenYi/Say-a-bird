/* pages/gallery/gallery.wxss */
.gallery-container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(to bottom, var(--bg-sky-day-1) 0%, var(--color-paper) 40%);
  padding: 60rpx 40rpx;
}

/* 进度区：硬阴影色块风格 */
.progress-section {
  background: white;
  border-radius: var(--radius-geometric);
  padding: 50rpx;
  margin-bottom: 60rpx;
  box-shadow: var(--shadow-hard);
  text-align: left;
  border: 4rpx solid var(--color-block-green);
}

.progress-title {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 40rpx;
}

.progress-display {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 20rpx;
}

.progress-number {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--color-block-green-dark);
}

progress {
  flex: 1;
  border-radius: 20rpx;
  overflow: hidden;
}

.progress-tip {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-style: italic;
  opacity: 0.7;
}

/* 分区标题：契合几何感 */
.section-header {
  margin-bottom: 40rpx;
  padding-left: 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-main);
  position: relative;
}

.section-title::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -10rpx;
  width: 40rpx;
  height: 6rpx;
  background: var(--color-block-orange);
}

/* 鸟类网格：非对称错落感的尝试（虽然 grid 很规整） */
.birds-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
  margin-bottom: 60rpx;
}

/* 鸟类卡片：几何拼贴+硬阴影 */
.bird-card {
  background: white;
  border-radius: var(--radius-geometric);
  padding: 40rpx 30rpx;
  box-shadow: var(--shadow-hard);
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.1s ease;
  border: 2rpx solid rgba(0,0,0,0.02);
}

.bird-card.unlocked:active {
  transform: translateY(6rpx);
  box-shadow: var(--shadow-hard-active);
}

.bird-card-image {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 30rpx;
  /* 模拟图片渲染清晰度 */
  image-rendering: pixelated;
}

.bird-card-silhouette {
  width: 180rpx;
  height: 180rpx;
  background: #F0F0F0;
  border-radius: var(--radius-geometric);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.lock-icon {
  font-size: 50rpx;
  opacity: 0.2;
}

.bird-card-info {
  width: 100%;
  text-align: center;
}

.bird-card-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-main);
  margin-bottom: 8rpx;
  display: block;
}

.bird-card-name.locked-name {
  color: var(--color-text-secondary);
  opacity: 0.5;
}

.bird-card-emotion {
  font-size: 22rpx;
  color: var(--color-block-orange-dark);
  background: rgba(255, 171, 145, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin-bottom: 16rpx;
}

.bird-card-knowledge {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  text-align: left;
  background: var(--color-paper);
  padding: 16rpx;
  border-radius: 8rpx;
  display: block;
}

.bird-card-count {
  font-size: 18rpx;
  color: var(--color-block-green-dark);
  margin-top: 16rpx;
  display: block;
  font-weight: bold;
}

.bird-card-hint {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  opacity: 0.5;
}

/* 未解锁卡片：低对比度 */
.bird-card.locked {
  background: rgba(255, 255, 255, 0.5);
  box-shadow: none;
  border: 2rpx dashed #E0E0E0;
}

/* 完成状态：金牌色块 */
.complete-card {
  background: var(--color-block-orange);
  border-radius: var(--radius-geometric);
  padding: 60rpx;
  text-align: center;
  box-shadow: 0 12rpx 0 var(--color-block-orange-dark);
  color: white;
}

.complete-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.complete-title {
  font-size: 40rpx;
  font-weight: 800;
  display: block;
  margin-bottom: 10rpx;
}

.complete-desc {
  font-size: 26rpx;
  opacity: 0.9;
}
