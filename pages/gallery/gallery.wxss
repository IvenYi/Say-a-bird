/* pages/gallery/gallery.wxss */
.gallery-container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(to bottom, var(--bg-sky-day-1) 0%, var(--color-paper) 40%);
  padding: 80rpx 40rpx;
}

/* 进度区 */
.progress-section {
  background: white;
  border-radius: var(--radius-zen);
  padding: 60rpx 50rpx;
  margin-bottom: 80rpx;
  box-shadow: var(--shadow-elevated);
  text-align: left;
}

.progress-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 40rpx;
}

.progress-display {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 24rpx;
}

.progress-number {
  font-size: 72rpx;
  font-weight: 600;
  color: var(--color-mint-dark);
}

progress {
  flex: 1;
  border-radius: 20rpx;
  overflow: hidden;
}

.progress-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-style: italic;
  opacity: 0.8;
}

/* 分区标题 */
.section-header {
  margin-bottom: 50rpx;
}

.section-title {
  font-size: 38rpx;
  font-weight: 600;
  color: var(--text-main);
  position: relative;
}

.section-title::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -12rpx;
  width: 50rpx;
  height: 10rpx;
  background: var(--color-warm-orange);
  border-radius: 5rpx;
}

/* 鸟类网格 */
.birds-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
  margin-bottom: 80rpx;
}

/* 鸟类卡片 */
.bird-card {
  background: white;
  border-radius: var(--radius-zen);
  padding: 48rpx 32rpx;
  box-shadow: var(--shadow-soft);
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.bird-card.unlocked:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.bird-card-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.bird-card-silhouette {
  width: 200rpx;
  height: 200rpx;
  background: #F0F0F0;
  border-radius: var(--radius-zen);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.lock-icon {
  font-size: 56rpx;
  opacity: 0.15;
}

.bird-card-info {
  width: 100%;
  text-align: center;
}

.bird-card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 12rpx;
  display: block;
}

.bird-card-name.locked-name {
  color: var(--text-secondary);
  opacity: 0.4;
}

.bird-card-emotion {
  font-size: 24rpx;
  color: var(--color-blue-dark);
  background: rgba(135, 169, 190, 0.1);
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  display: inline-block;
  margin-bottom: 20rpx;
}

.bird-card-knowledge {
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  text-align: left;
  background: var(--color-paper);
  padding: 20rpx;
  border-radius: 16rpx;
  display: block;
}

/* 未解锁卡片 */
.bird-card.locked {
  background: rgba(255, 255, 255, 0.4);
  box-shadow: none;
  opacity: 0.7;
}

/* 完成状态 */
.complete-card {
  background: var(--color-warm-orange);
  border-radius: var(--radius-zen);
  padding: 80rpx 60rpx;
  text-align: center;
  box-shadow: var(--shadow-accent);
  color: white;
}

.complete-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 24rpx;
}

.complete-title {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.complete-desc {
  font-size: 28rpx;
  opacity: 0.9;
}
