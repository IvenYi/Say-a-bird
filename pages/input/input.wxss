/* pages/input/input.wxss */
.input-container {
  width: 100%;
  min-height: 100vh;
  /* 使用温润的“纸张白”与天空色的过渡 */
  background: linear-gradient(to bottom, var(--bg-sky-day-1) 0%, var(--color-paper) 40%);
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
}

/* 噪点层依然需要 */
.noise-overlay {
  position: fixed;
  inset: 0;
  z-index: 10;
  pointer-events: none;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
}

/* 顶部引导：非标准化排版 */
.input-header {
  text-align: left;
  margin-bottom: 80rpx;
  padding-left: 10rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--color-text-main);
  display: block;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  display: block;
  font-style: italic;
  opacity: 0.7;
}

/* 输入区域：无边框“纸张”感 */
.input-area {
  width: 100%;
  margin-bottom: 60rpx;
  position: relative;
}

.input-textarea {
  width: 100%;
  min-height: 500rpx;
  padding: 0;
  background: transparent;
  font-size: 34rpx;
  line-height: 2;
  color: var(--color-text-main);
}

.input-placeholder {
  color: var(--color-text-secondary);
  opacity: 0.4;
}

/* 装饰性分割线：色块风 */
.input-area::after {
  content: "";
  position: absolute;
  bottom: -20rpx;
  left: 0;
  width: 120rpx;
  height: 8rpx;
  background: var(--color-block-green);
  border-radius: 4rpx;
}

.char-count {
  position: absolute;
  bottom: -60rpx;
  right: 0;
}

.count-text {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  letter-spacing: 2rpx;
}

/* 语音输入：几何块风格 */
.voice-input-section {
  width: 100%;
  margin-top: 100rpx;
  margin-bottom: 60rpx;
}

.voice-btn {
  width: 100%;
  height: 110rpx;
  background: white;
  border-radius: var(--radius-geometric);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  box-shadow: var(--shadow-hard);
  border: none;
  transition: all 0.1s ease;
}

.voice-btn::after {
  border: none;
}

.voice-btn.recording {
  background: var(--color-block-orange);
  transform: translateY(6rpx);
  box-shadow: var(--shadow-hard-active);
}

.voice-icon {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.6;
}

.voice-text {
  font-size: 28rpx;
  color: var(--color-text-main);
  font-weight: 500;
}

.voice-btn.recording .voice-text {
  color: white;
}

/* 底部操作按钮：硬阴影色块 */
.bottom-actions {
  width: 100%;
  display: flex;
  gap: 30rpx;
  margin-top: 40rpx;
}

.empty-btn {
  flex: 1;
  height: 100rpx;
  background: white;
  border: 4rpx solid var(--color-block-green);
  border-radius: var(--radius-geometric);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-btn::after {
  border: none;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-block-green-dark);
  font-weight: bold;
}

.submit-btn {
  flex: 1.5;
  height: 100rpx;
  background: var(--color-block-orange);
  border-radius: var(--radius-geometric);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 0 var(--color-block-orange-dark);
  transition: all 0.1s ease;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: translateY(6rpx);
  box-shadow: 0 2rpx 0 var(--color-block-orange-dark);
}

.submit-text {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
}

/* 温馨提示 */
.tips-section {
  margin-top: 80rpx;
  padding: 30rpx;
  background: rgba(0, 0, 0, 0.02);
  border-radius: var(--radius-geometric);
}

.tip-item {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 10rpx;
  text-align: center;
}
