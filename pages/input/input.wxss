/* pages/input/input.wxss */
.input-container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(to bottom, var(--bg-sky-day-1) 0%, var(--color-paper) 40%);
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
}

/* 顶部引导 */
.input-header {
  margin-bottom: 80rpx;
}

.header-title {
  font-size: 52rpx;
  font-weight: 600;
  color: var(--text-main);
  display: block;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.header-subtitle {
  font-size: 30rpx;
  color: var(--text-secondary);
  display: block;
  font-style: italic;
  opacity: 0.8;
}

/* 输入区域 */
.input-area {
  width: 100%;
  margin-bottom: 80rpx;
  position: relative;
}

.input-textarea {
  width: 100%;
  min-height: 500rpx;
  padding: 0;
  background: transparent;
  font-size: 36rpx;
  line-height: 1.8;
  color: var(--text-main);
}

.input-placeholder {
  color: var(--text-secondary);
  opacity: 0.4;
}

/* 装饰性色块线 */
.input-area::after {
  content: "";
  position: absolute;
  bottom: -20rpx;
  left: 0;
  width: 140rpx;
  height: 10rpx;
  background: var(--color-mint);
  border-radius: 5rpx;
}

.char-count {
  position: absolute;
  bottom: -60rpx;
  right: 0;
}

.count-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  opacity: 0.6;
}

/* 语音输入 */
.voice-input-section {
  width: 100%;
  margin-top: 60rpx;
  margin-bottom: 60rpx;
}

.voice-btn {
  width: 100%;
  height: 120rpx;
  background: white;
  border-radius: var(--radius-zen);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  box-shadow: var(--shadow-soft);
  border: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.voice-btn.recording {
  background: var(--color-warm-orange);
  transform: scale(0.98);
  box-shadow: 0 8rpx 16rpx rgba(var(--color-warm-orange-rgb), 0.2);
}

.voice-text {
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 500;
}

.voice-btn.recording .voice-text {
  color: white;
}

/* 底部操作按钮 */
.bottom-actions {
  width: 100%;
  display: flex;
  gap: 30rpx;
  margin-top: 40rpx;
}

.empty-btn {
  flex: 1;
  height: 100rpx;
  background: white;
  border-radius: var(--radius-zen);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-soft);
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-mint-dark);
  font-weight: 600;
}

.submit-btn {
  flex: 1.5;
  height: 100rpx;
  background: var(--color-warm-orange);
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-accent);
  transition: all 0.3s ease;
}

.submit-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 8rpx 16rpx rgba(255, 171, 145, 0.15);
}

.submit-text {
  font-size: 30rpx;
  color: white;
  font-weight: 600;
}

/* 提示 */
.tips-section {
  margin-top: 80rpx;
  padding: 40rpx;
  background: rgba(var(--color-warm-orange-rgb), 0.05);
  border-radius: var(--radius-zen);
}

.tip-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
  text-align: center;
}
