/* pages/sky/sky.wxss */
.sky-container {
  width: 100%;
  height: 100vh;
  position: relative;
  transition: all 1.5s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}

.sky-dawn { background: linear-gradient(to bottom, var(--bg-sky-dawn-1), var(--bg-sky-dawn-2)); }
.sky-day { background: linear-gradient(to bottom, var(--bg-sky-day-1), var(--bg-sky-day-2)); }
.sky-dusk { background: linear-gradient(to bottom, var(--bg-sky-dusk-1), var(--bg-sky-dusk-2)); }
.sky-night { background: linear-gradient(to bottom, var(--bg-sky-night-1), var(--bg-sky-night-2)); }

.status-bar-placeholder {
  height: 120rpx; /* 适配异形屏状态栏 */
  width: 100%;
}

/* 核心画布区域：完全全屏 */
.sky-canvas-wrapper {
  width: 100vw;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

/* 2D 无限长卷容器 */
.infinite-canvas {
  width: 300vw; /* 横向3倍宽 */
  height: 250vh; /* 纵向2.5倍高 */
  position: relative;
  /* 背景渐变由父容器处理，这里保持透明 */
}

/* =========================================
   三栖生态基底 (Geometric Eco-Base)
========================================= */
.eco-base {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 300vw; /* 撑满横向长卷 */
  height: 80vh; /* 底部生态区高度 */
  pointer-events: none;
  z-index: 1; /* 在鸟类之下 */
  overflow: hidden;
}

/* 1. 远景：山丘起伏 */
.eco-hill {
  position: absolute;
  bottom: 10vh;
  border-radius: 50% 50% 0 0;
  background: var(--color-block-green);
  opacity: 0.15; /* 随天空自动融合 */
}
.eco-hill-left {
  width: 120vw;
  height: 30vh;
  left: -10vw;
}
.eco-hill-right {
  width: 150vw;
  height: 25vh;
  left: 80vw;
  bottom: 15vh;
  background: var(--color-forest);
  opacity: 0.1;
}

/* 2. 前景：蜿蜒水域与错落滩涂 (Winding River) */
.eco-winding-river {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 300vw;
  height: 25vh;
  z-index: 10; /* 确保在最前面 */
}

.mudflat-curve {
  position: absolute;
  background: var(--color-forest);
  opacity: 0.35;
  border-radius: 50%;
}
.mudflat-1 { width: 80vw; height: 30vh; bottom: -5vh; left: 120vw; }
.mudflat-2 { width: 100vw; height: 20vh; bottom: -2vh; left: 180vw; opacity: 0.25; }
.mudflat-3 { width: 60vw; height: 15vh; bottom: 5vh; left: 220vw; }

.water-curve {
  position: absolute;
  background: linear-gradient(to bottom, rgba(168, 213, 186, 0.4), rgba(74, 103, 65, 0.9));
  backdrop-filter: blur(4px);
  border-radius: 50%;
  border-top: 2rpx solid rgba(255,255,255,0.2);
}
.water-1 { width: 180vw; height: 40vh; bottom: -20vh; left: -20vw; }
.water-2 { width: 200vw; height: 30vh; bottom: -10vh; left: 120vw; }

/* 3. 左侧：几何层叠森林 (Layered Geometric Forest) */
.eco-forest {
  position: absolute;
  bottom: 12vh;
  left: 10vw; 
  width: 100vw;
  height: 40vh;
}

/* 几何松树 (多层三角形) */
.tree-pine {
  position: absolute;
  bottom: 0;
  width: 16vw;
  height: 30vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}
.tree-pine::before { /* 树干 */
  content: "";
  position: absolute;
  bottom: 0;
  width: 1.5vw;
  height: 6vh;
  background: #5D4037;
  z-index: 1;
  border-radius: 1vw;
}
.pine-layer {
  width: 0;
  height: 0;
  border-left: 8vw solid transparent;
  border-right: 8vw solid transparent;
  border-bottom: 12vh solid var(--color-forest);
  margin-bottom: -6vh; /* 层叠覆盖 */
  position: relative;
  z-index: 2;
  opacity: 0.9;
}
.pine-layer:nth-child(1) { border-bottom-width: 10vh; border-left-width: 6vw; border-right-width: 6vw; z-index: 4; }
.pine-layer:nth-child(2) { border-bottom-width: 12vh; border-left-width: 7vw; border-right-width: 7vw; z-index: 3; }
.pine-layer:nth-child(3) { border-bottom-width: 14vh; z-index: 2; }

/* 几何圆冠树 (多层圆形) */
.tree-round {
  position: absolute;
  bottom: 0;
  width: 24vw;
  height: 24vw;
}
.tree-round::after { /* 树干 */
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 2vw;
  height: 10vh;
  background: #5D4037;
  z-index: 1;
  border-radius: 2vw;
}
.round-layer {
  position: absolute;
  background: var(--color-block-green);
  border-radius: 50%;
  z-index: 2;
  box-shadow: inset -2vw -2vw 0 rgba(0,0,0,0.1);
}
.round-layer:nth-child(1) { width: 14vw; height: 14vw; top: 0; left: 5vw; z-index: 4; }
.round-layer:nth-child(2) { width: 12vw; height: 12vw; top: 6vw; left: 0; background: var(--color-block-green-dark); z-index: 3; }
.round-layer:nth-child(3) { width: 16vw; height: 16vw; top: 4vw; right: 0; z-index: 3; }

/* 树木错落分布 */
.tree-1 { left: 0; transform: scale(1.1); z-index: 1; }
.tree-2 { left: 20vw; transform: scale(1.3); z-index: 3; }
.tree-3 { left: 50vw; transform: scale(0.8); z-index: 0; opacity: 0.8; }


/* =========================================
   UI 与视差特效层 (Camera Lens & God Rays)
========================================= */

/* 固定前景画框 */
.framing-layer {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 100; /* 高于 scroll-view，低于 UI */
}
.framing-leaf {
  position: absolute;
  top: -10vh;
  width: 40vw;
  height: 60vh;
  background: var(--color-block-green-dark);
  border-radius: 50%;
  filter: blur(8px); /* 镜头外的失焦感 */
  opacity: 0.8;
  mix-blend-mode: multiply; /* 融入天空背景 */
}
.framing-left { left: -20vw; transform: rotate(15deg); }
.framing-right { right: -25vw; top: -5vh; transform: rotate(-20deg) scale(1.2); }

/* 神明光 (丁达尔效应) */
.god-rays-layer {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 50; /* 在背景之上，树木之下或交织 */
  overflow: hidden;
}
.ray {
  position: absolute;
  top: -20vh;
  width: 15vw;
  height: 150vh;
  background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);
  transform-origin: top center;
  mix-blend-mode: overlay;
  filter: blur(10px);
}
.ray-1 { left: 30vw; transform: rotate(25deg); }
.ray-2 { left: 60vw; transform: rotate(30deg); width: 25vw; opacity: 0.6; }

/* 鸟类容器 */
.birds-container {
  width: 300vw;
  height: 250vh;
  position: relative;
}

/* 鸟类项：悬浮在画布的绝对位置 */
.bird-item {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 去掉 Entrance 动画，因为现在是绝对定位，可能不在视野内 */
  animation: birdFloatZen 6s ease-in-out infinite;
}

.bird-emoji {
  font-size: 100rpx;
}

/* 极简解锁提示点 */
.unlock-dot {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 12rpx;
  height: 12rpx;
  background: var(--color-block-orange);
  border-radius: 50%;
  box-shadow: 0 0 10rpx var(--color-block-orange);
}

/* 沉浸式导航组：底部悬浮 */
.zen-navigation {
  position: fixed;
  bottom: 80rpx;
  left: 0;
  right: 0;
  display: flex;
  align-items: flex-end; /* 底部对齐 */
  justify-content: space-around;
  padding: 0 40rpx;
  z-index: 1000;
}

/* 核心交互区包装器 */
.main-action-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

/* 隐藏的文字输入入口 */
.sub-action-btn {
  position: absolute;
  top: -50rpx;
  right: -30rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.6;
  transition: all 0.3s ease;
  z-index: 10;
}

.sub-action-btn:active {
  transform: scale(0.9);
  opacity: 1;
  background: rgba(255, 255, 255, 0.3);
}

.sub-action-icon {
  font-size: 28rpx;
}

/* 长按放空提示 */
.long-press-hint {
  position: absolute;
  bottom: -40rpx;
  font-size: 20rpx;
  color: var(--color-text-main);
  opacity: 0.3;
  letter-spacing: 2rpx;
  animation: breatheHint 4s ease-in-out infinite;
  white-space: nowrap;
}

@keyframes breatheHint {
  0%, 100% { opacity: 0.15; }
  50% { opacity: 0.4; }
}

/* 文字输入遮罩层 */
.text-input-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(245, 245, 245, 0.85); /* 纸张白带透明度 */
  backdrop-filter: blur(40rpx); /* 强毛玻璃效果 */
  z-index: 2000;
  display: flex;
  flex-direction: column;
  padding: 120rpx 60rpx 60rpx;
}

.input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 60rpx;
}

.cancel-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  padding: 20rpx 0;
}

.send-btn {
  margin: 0;
  padding: 0 40rpx;
  height: 64rpx;
  line-height: 64rpx;
  background: var(--color-block-orange);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 32rpx;
  box-shadow: var(--shadow-hard);
}

.send-btn[disabled] {
  background: #E0E0E0;
  color: #9E9E9E;
  box-shadow: none;
}

.zen-textarea {
  width: 100%;
  flex: 1;
  background: transparent;
  font-size: 40rpx;
  line-height: 1.8;
  color: var(--color-text-main);
  font-weight: 300;
  letter-spacing: 2rpx;
}

.zen-placeholder {
  color: var(--color-text-secondary);
  opacity: 0.4;
  font-style: italic;
}

/* 侧边小图标 */
.nav-icon-box {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.3; /* 极低不透明度，仅在视觉余光中存在 */
  transition: opacity 0.3s ease;
}

.nav-icon-box:active {
  opacity: 0.8;
}

.nav-icon {
  font-size: 44rpx;
}

/* 核心交互按钮：参考 Scribe/交互灵感 */
.zen-main-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.action-circle {
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(20rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 0 1rpx rgba(255, 255, 255, 0.1);
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.zen-main-action:active .action-circle {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.4);
}

.action-bird {
  font-size: 70rpx;
}

.action-label {
  font-size: 24rpx;
  color: var(--color-text-main);
  font-weight: 300;
  letter-spacing: 4rpx;
  opacity: 0.6;
}

/* 视图切换：极其隐秘 */
.view-switch-zen {
  position: fixed;
  top: 140rpx;
  right: 40rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 20rpx;
  opacity: 0.2;
  transition: opacity 0.3s ease;
}

.view-switch-zen:active {
  opacity: 0.8;
}

.switch-dot {
  width: 8rpx;
  height: 8rpx;
  background: var(--color-text-main);
  border-radius: 50%;
}

.switch-label {
  font-size: 20rpx;
  color: var(--color-text-main);
}

/* 诗意化空状态 */
.empty-state {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  width: 80%;
}

.empty-quote {
  font-size: 32rpx;
  color: var(--color-text-main);
  opacity: 0.4;
  display: block;
  margin-bottom: 20rpx;
  font-style: italic;
  letter-spacing: 2rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  opacity: 0.3;
}

/* 动效定义 */
@keyframes birdEntranceZen {
  from {
    opacity: 0;
    filter: blur(20rpx);
    transform: scale(0.8) translateY(100rpx);
  }
  to {
    opacity: 1;
    filter: blur(0);
    transform: scale(1) translateY(0);
  }
}

@keyframes birdFloatZen {
  0%, 100% {
    transform: translate(0, 0) rotate(0deg);
  }
  33% {
    transform: translate(10rpx, -20rpx) rotate(3deg);
  }
  66% {
    transform: translate(-10rpx, -10rpx) rotate(-2deg);
  }
}

/* 录音交互相关样式 */
.recording-overlay {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 500;
  animation: fadeInZen 0.5s ease;
}

.recording-title {
  font-size: 36rpx;
  color: var(--color-text-main);
  font-weight: 500;
  letter-spacing: 4rpx;
  margin-bottom: 60rpx;
  opacity: 0.9;
  font-style: italic;
}

.sound-wave {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 80rpx;
  margin-bottom: 30rpx;
}

.wave-bar {
  width: 6rpx;
  background: var(--color-text-main);
  border-radius: 6rpx;
  animation: wavePulseZen 1.2s ease-in-out infinite;
  opacity: 0.8;
}

.wave-bar:nth-child(1) { height: 30rpx; animation-delay: 0.0s; }
.wave-bar:nth-child(2) { height: 60rpx; animation-delay: 0.2s; }
.wave-bar:nth-child(3) { height: 80rpx; animation-delay: 0.4s; }
.wave-bar:nth-child(4) { height: 60rpx; animation-delay: 0.6s; }
.wave-bar:nth-child(5) { height: 30rpx; animation-delay: 0.8s; }

.recording-hint {
  font-size: 24rpx;
  color: var(--color-text-main);
  letter-spacing: 12rpx;
  font-weight: 300;
  opacity: 0.5;
}

/* 录音中的底部按钮变化 */
.zen-main-action.recording .action-circle {
  transform: scale(1.1);
  background: rgba(255, 255, 255, 0.6);
  box-shadow: 0 0 30rpx rgba(255, 255, 255, 0.5);
  animation: pulseGlow 2s infinite;
}

.zen-main-action.recording .action-label {
  color: var(--color-block-orange);
  opacity: 1;
  font-weight: bold;
}

.stop-square {
  width: 40rpx;
  height: 40rpx;
  background: var(--color-block-orange);
  border-radius: 8rpx;
}

/* 录音相关动效 */
@keyframes fadeInZen {
  from { opacity: 0; transform: translate(-50%, -40%); }
  to { opacity: 1; transform: translate(-50%, -50%); }
}

@keyframes wavePulseZen {
  0%, 100% { transform: scaleY(0.4); opacity: 0.4; }
  50% { transform: scaleY(1); opacity: 1; }
}

@keyframes pulseGlow {
  0% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.4); }
  70% { box-shadow: 0 0 0 30rpx rgba(255, 255, 255, 0); }
  100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
}
