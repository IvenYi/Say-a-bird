/* pages/sky/sky.wxss */
.sky-container {
  width: 100%;
  height: 100vh;
  position: relative;
  transition: all 1.5s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}

.sky-dawn { background: linear-gradient(to bottom, var(--bg-sky-dawn-1), var(--bg-sky-dawn-2)); }
.sky-day { background: linear-gradient(to bottom, var(--bg-sky-day-1), var(--bg-sky-day-2)); }
.sky-dusk { background: linear-gradient(to bottom, var(--bg-sky-dusk-1), var(--bg-sky-dusk-2)); }
.sky-night { background: linear-gradient(to bottom, var(--bg-sky-night-1), var(--bg-sky-night-2)); }

/* 核心画布区域：全屏沉浸 */
.sky-canvas-wrapper {
  width: 100vw;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

/* 2D 无限长卷容器 */
.infinite-canvas {
  width: 300vw;
  height: 250vh;
  position: relative;
}

/* =========================================
   三栖生态基底 (Stroke-less Geometric Eco-Base)
========================================= */
.eco-base {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 300vw;
  height: 80vh;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}

/* 1. 远景：山丘起伏 */
.eco-hill {
  position: absolute;
  bottom: 10vh;
  border-radius: 50% 50% 0 0;
  background: var(--color-mint);
  opacity: 0.15;
}
.eco-hill-left {
  width: 120vw;
  height: 30vh;
  left: -10vw;
}
.eco-hill-right {
  width: 150vw;
  height: 25vh;
  left: 80vw;
  bottom: 15vh;
  background: var(--color-mint-dark);
  opacity: 0.1;
}

/* 2. 前景：水域与滩涂 (Winding River) */
.eco-winding-river {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 300vw;
  height: 25vh;
  z-index: 10;
}

.mudflat-curve {
  position: absolute;
  background: var(--color-mint-dark);
  opacity: 0.35;
  border-radius: 50%;
}
.mudflat-1 { width: 80vw; height: 30vh; bottom: -5vh; left: 120vw; }
.mudflat-2 { width: 100vw; height: 20vh; bottom: -2vh; left: 180vw; opacity: 0.25; }
.mudflat-3 { width: 60vw; height: 15vh; bottom: 5vh; left: 220vw; }

.water-curve {
  position: absolute;
  background: linear-gradient(to bottom, rgba(168, 213, 186, 0.4), rgba(74, 103, 65, 0.8));
  backdrop-filter: blur(4px);
  border-radius: 50%;
  /* V2: 移除所有描边线 */
}
.water-1 { width: 180vw; height: 40vh; bottom: -20vh; left: -20vw; }
.water-2 { width: 200vw; height: 30vh; bottom: -10vh; left: 120vw; }

/* 3. 层叠几何森林 (Layered Geometric Forest) */
.eco-forest {
  position: absolute;
  bottom: 12vh;
  left: 10vw; 
  width: 100vw;
  height: 40vh;
}

.tree-pine {
  position: absolute;
  bottom: 0;
  width: 16vw;
  height: 30vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}
.tree-pine::before {
  content: "";
  position: absolute;
  bottom: 0;
  width: 1.5vw;
  height: 6vh;
  background: #5D4037;
  z-index: 1;
  border-radius: 1vw;
}
.pine-layer {
  width: 0;
  height: 0;
  border-left: 8vw solid transparent;
  border-right: 8vw solid transparent;
  border-bottom: 12vh solid var(--color-mint-dark);
  margin-bottom: -6vh;
  position: relative;
  z-index: 2;
  opacity: 0.9;
}
.pine-layer:nth-child(1) { border-bottom-width: 10vh; border-left-width: 6vw; border-right-width: 6vw; z-index: 4; }
.pine-layer:nth-child(2) { border-bottom-width: 12vh; border-left-width: 7vw; border-right-width: 7vw; z-index: 3; }

.tree-round {
  position: absolute;
  bottom: 0;
  width: 24vw;
  height: 24vw;
}
.tree-round::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 2vw;
  height: 10vh;
  background: #5D4037;
  z-index: 1;
  border-radius: 2vw;
}
.round-layer {
  position: absolute;
  background: var(--color-mint);
  border-radius: 50%;
  z-index: 2;
  box-shadow: inset -2vw -2vw 0 rgba(0,0,0,0.05);
}
.round-layer:nth-child(1) { width: 14vw; height: 14vw; top: 0; left: 5vw; z-index: 4; }
.round-layer:nth-child(2) { width: 12vw; height: 12vw; top: 6vw; left: 0; background: var(--color-mint-dark); z-index: 3; }
.round-layer:nth-child(3) { width: 16vw; height: 16vw; top: 4vw; right: 0; z-index: 3; }


/* =========================================
   UI 与特效层
========================================= */

/* 固定前景画框 (Camera Lens) */
.framing-layer {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 100;
}
.framing-leaf {
  position: absolute;
  top: -10vh;
  width: 40vw;
  height: 60vh;
  background: var(--color-mint-dark);
  border-radius: 50%;
  filter: blur(20px); /* 增加模糊度营造失焦感 */
  opacity: 0.6;
  mix-blend-mode: multiply;
}
.framing-left { left: -20vw; transform: rotate(15deg); }
.framing-right { right: -25vw; top: -5vh; transform: rotate(-20deg) scale(1.2); }

/* 神明光 */
.god-rays-layer {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 50;
  overflow: hidden;
}
.ray {
  position: absolute;
  top: -20vh;
  width: 15vw;
  height: 150vh;
  background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
  transform-origin: top center;
  mix-blend-mode: overlay;
  filter: blur(15px);
}
.ray-1 { left: 30vw; transform: rotate(25deg); }
.ray-2 { left: 60vw; transform: rotate(30deg); width: 25vw; opacity: 0.5; }

/* 鸟类项 */
.bird-item {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: birdFloatZen 6s ease-in-out infinite;
}

.bird-emoji {
  font-size: 100rpx;
  filter: drop-shadow(0 10rpx 20rpx rgba(0,0,0,0.1));
}

/* 解锁提示点 */
.unlock-dot {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 12rpx;
  height: 12rpx;
  background: var(--color-warm-orange);
  border-radius: 50%;
  box-shadow: 0 0 10rpx var(--color-warm-orange);
}

/* 沉浸式导航组 */
.zen-navigation {
  position: fixed;
  bottom: calc(80rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  padding: 0 40rpx;
  z-index: 1000;
}

/* 核心交互按钮 */
.zen-main-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.action-circle {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(20px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-soft);
  transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}

.zen-main-action:active .action-circle {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.4);
}

.action-bird {
  font-size: 72rpx;
}

.action-label {
  font-size: 24rpx;
  color: var(--text-main);
  font-weight: 400;
  letter-spacing: 4rpx;
  opacity: 0.7;
}

/* 文字输入遮罩 (Glassmorphism) */
.text-input-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(245, 245, 245, 0.88);
  backdrop-filter: blur(40px);
  z-index: 2000;
  display: flex;
  flex-direction: column;
  padding: calc(120rpx + env(safe-area-inset-top)) 60rpx 60rpx;
}

.input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 60rpx;
}

.cancel-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  padding: 20rpx 0;
}

.send-btn {
  margin: 0;
  padding: 0 50rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--color-warm-orange);
  color: white;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 36rpx;
  box-shadow: var(--shadow-accent);
}

.zen-textarea {
  width: 100%;
  flex: 1;
  background: transparent;
  font-size: 42rpx;
  line-height: 1.8;
  color: var(--text-main);
  letter-spacing: 2rpx;
}

/* 录音声波层 */
.recording-overlay {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 500;
}

.recording-title {
  font-size: 36rpx;
  color: var(--text-main);
  font-weight: 500;
  letter-spacing: 4rpx;
  margin-bottom: 60rpx;
  font-style: italic;
}

.sound-wave {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 80rpx;
  margin-bottom: 40rpx;
}

.wave-bar {
  width: 6rpx;
  background: var(--color-warm-orange);
  border-radius: 6rpx;
  animation: wavePulseZen 1.2s ease-in-out infinite;
}

/* 视图切换 */
.view-switch-zen {
  position: fixed;
  top: calc(140rpx + env(safe-area-inset-top));
  right: 40rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border-radius: 100rpx;
  opacity: 0.4;
  transition: opacity 0.3s ease;
}

.view-switch-zen:active { opacity: 0.9; }

/* 动画定义 */
@keyframes birdFloatZen {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(10rpx, -20rpx) rotate(3deg); }
  66% { transform: translate(-10rpx, -10rpx) rotate(-2deg); }
}

@keyframes wavePulseZen {
  0%, 100% { transform: scaleY(0.4); opacity: 0.4; }
  50% { transform: scaleY(1); opacity: 1; }
}
